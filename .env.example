# NetGuard IDS — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to version control.

# ── API Authentication ──────────────────────────────────────────────────────
# Required if api.enabled=true in config.yaml
NETGUARD_API_KEY=changeme

# ── Email / SMTP Notifications ──────────────────────────────────────────────
# Required if notifications.email=true in config.yaml
NETGUARD_SMTP_USER=your-email@example.com
NETGUARD_SMTP_PASSWORD=your-app-password

# ── Twilio SMS Notifications (optional) ─────────────────────────────────────
NETGUARD_TWILIO_SID=
NETGUARD_TWILIO_TOKEN=
NETGUARD_TWILIO_FROM=
NETGUARD_TWILIO_TO=

# ── GeoIP API (optional) ────────────────────────────────────────────────────
GEOIP_API_KEY=
